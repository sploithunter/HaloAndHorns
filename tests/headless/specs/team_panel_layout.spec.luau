local Layout = loadModule("src/Client/UI/Menus/TeamPanelLayout.lua")

return function()
    describe("TeamPanelLayout.panelSize", function()
        it("caps the panel on a large landscape tablet", function()
            local size = Layout.panelSize(2048, 946)
            expect(size.width).to.equal(760)
            expect(size.height).to.equal(520)
        end)

        it("fits a phone in landscape without exceeding the safe viewport", function()
            local size = Layout.panelSize(844, 390)
            expect(size.width).to.equal(557)
            expect(size.height).to.equal(304)
            expect(size.width <= 820).to.equal(true)
            expect(size.height <= 366).to.equal(true)
        end)

        it("uses most of a narrow portrait screen", function()
            local size = Layout.panelSize(390, 844)
            expect(size.width).to.equal(351)
            expect(size.height).to.equal(520)
        end)

        it("never overflows even an unusually small viewport", function()
            local size = Layout.panelSize(320, 240)
            expect(size.width <= 296).to.equal(true)
            expect(size.height <= 216).to.equal(true)
        end)
    end)

    describe("TeamPanelLayout.content", function()
        it("leaves room for multiple invite rows on a landscape phone", function()
            local content = Layout.content(304, false)
            expect(content.compact).to.equal(true)
            expect(content.listHeight >= 112).to.equal(true)
        end)

        it("reserves a footer only when a team can be left", function()
            local solo = Layout.content(520, false)
            local teamed = Layout.content(520, true)
            expect(solo.listHeight > teamed.listHeight).to.equal(true)
        end)
    end)
end
